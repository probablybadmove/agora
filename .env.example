# Agora is fully functional without these — the site ships with a bundled catalog.
# Set them to serve the catalog live from Supabase instead (see supabase/ for schema + seed).
#
# Only the *publishable* (anon) key goes here. It is safe to expose to the browser and is
# gated by row-level security (public read-only on the catalog tables). Never put the
# service-role key in an EXPO_PUBLIC_* variable.

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
